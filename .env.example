# Copy to .env and fill in. NEVER commit real secrets.

# --- identity ---
# Wallet that receives all revenue and pays game winnings (the agent's wallet).
AGENT_ADDRESS=0xYourAgentWallet
# Private key of AGENT_ADDRESS. Needed for trades, payouts, and registration.
AGENT_PRIVATE_KEY=

# Public base URL where this server is reachable (no trailing slash).
PUBLIC_BASE_URL=https://bureau.example.com

# Agent metadata
AGENT_NAME=Bureau
AGENT_DESCRIPTION=Autonomous FX desk on Celo. Trades Mento stablecoins against real-world FX and sells market data per-call via x402, settled in USDC.
AGENT_IMAGE_URL=

# --- x402 ---
# Celo facilitator API (mainnet). Testnet: https://api.x402.sepolia.celo.org
X402_FACILITATOR_URL=https://api.x402.celo.org
# API key from x402.celo.org (sign-in with the agent wallet; scriptable: npm run x402:key).
X402_API_KEY=

# --- chain ---
CELO_RPC=https://forno.celo.org
# Pay gas in a Celo fee currency instead of native CELO. Leave EMPTY to use CELO
# (recommended: paying gas in the token the desk also trades collides with sizing).
FEE_CURRENCY=

# --- pricing (USDC, 6 decimals => 10000 = $0.01) ---
PRICE_MICRO=5000
PRICE_LOOKUP=10000
PRICE_PREMIUM=250000

# --- game economics (atomic USDC) ---
# win pays stake * PAYOUT_NUM / 100; draw refunds stake * DRAW_REFUND_NUM / 100
# (the draw fee is the table rake that keeps the house solvent vs perfect players)
GAME_NORMAL_STAKE=100000
GAME_NORMAL_PAYOUT_NUM=150
GAME_NORMAL_DRAW_REFUND_NUM=80
GAME_HARD_STAKE=250000
GAME_HARD_PAYOUT_NUM=300
GAME_HARD_DRAW_REFUND_NUM=70
# bot blunder probability per move (0..1)
GAME_NORMAL_BLUNDER=0.08
GAME_HARD_BLUNDER=0.03
# max paid games per payer wallet per UTC day
GAME_DAILY_CAP=50

# --- attribution ---
# ERC-8021 tag (celo_ + 12 hex). Appended to every transaction the agent sends.
ATTRIBUTION_TAG=

# --- server ---
PORT=3000

# --- desk (FX trading) ---
DESK_ENABLED=0
DESK_BASE=USDm
# Leave EMPTY to scan every Mento stable automatically; set a comma list to restrict.
DESK_PAIRS=
DESK_TRADE_USD=8
DESK_INTERVAL_SEC=120
DESK_MIN_EDGE_BPS=6
DESK_ROTATION=1
DESK_MAX_ROTATION_COST_BPS=20
# wider allowance for a rebalance sell when the base balance runs dry
DESK_REBALANCE_COST_BPS=60
DESK_DAILY_COST_CAP_USD=1.0
DESK_SLIPPAGE=0.3
# low-CELO safety threshold (warns/guards when the gas tank runs low)
DESK_MIN_CELO=0.15
# token for POST /v1/desk/pause kill switch
ADMIN_TOKEN=

# --- x402 self-consumption loop ---
# The desk buys its own data feed the way any customer would (real settlements).
SELF_BUY_ENABLED=0
# separate wallet that pays for the feed; the agent refills it automatically
PAYER_PRIVATE_KEY=
SELF_BUY_INTERVAL_SEC=120
SELF_BUY_REFILL_BELOW_USD=0.6
SELF_BUY_REFILL_USD=1.5
# every Nth call fetches the premium wallet report (more volume, same cost); 0 disables
SELF_BUY_PREMIUM_EVERY=3
