# Copy to .env and fill in. NEVER commit real secrets.

# --- identity ---
# Wallet that receives all revenue and pays game winnings (the agent's wallet).
AGENT_ADDRESS=0xYourAgentWallet
# Private key of AGENT_ADDRESS. Needed for game payouts and ERC-8004 registration.
AGENT_PRIVATE_KEY=

# Public base URL where this server is reachable (no trailing slash).
PUBLIC_BASE_URL=https://kiosk.example.com

# Agent metadata
AGENT_NAME=Kiosk
AGENT_DESCRIPTION=Autonomous storefront agent on Celo. Pays-per-call market data, onchain lookups, and stake-to-play arcade games, all settled in USDC via x402.
AGENT_IMAGE_URL=

# --- x402 ---
# Celo facilitator API (mainnet). Testnet: https://api.x402.sepolia.celo.org
X402_FACILITATOR_URL=https://api.x402.celo.org
# API key from x402.celo.org (sign-in with the agent wallet, prepaid credits).
X402_API_KEY=

# --- chain ---
CELO_RPC=https://forno.celo.org

# --- pricing (USDC, 6 decimals => 10000 = $0.01) ---
PRICE_MICRO=5000
PRICE_LOOKUP=10000
PRICE_PREMIUM=250000

# --- game economics (atomic USDC) ---
# win pays stake * PAYOUT_NUM / 100; draw refunds stake * DRAW_REFUND_NUM / 100
# (the draw fee is the table rake that keeps the house solvent vs perfect players)
GAME_NORMAL_STAKE=100000
GAME_NORMAL_PAYOUT_NUM=150
GAME_NORMAL_DRAW_REFUND_NUM=80
GAME_HARD_STAKE=250000
GAME_HARD_PAYOUT_NUM=300
GAME_HARD_DRAW_REFUND_NUM=70
# bot blunder probability per move (0..1)
GAME_NORMAL_BLUNDER=0.08
GAME_HARD_BLUNDER=0.03
# max paid games per payer wallet per UTC day
GAME_DAILY_CAP=50

# --- attribution ---
# ERC-8021 tag (celo_ + 12 hex). Appended to every transaction the agent sends.
ATTRIBUTION_TAG=

# --- server ---
PORT=3000
